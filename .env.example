# ============================================================
# Speakeasy Backend - Environment Variables
# Copy this file to .env and fill in your real values.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_ENV=development            # development | production
APP_PORT=8000                  # FastAPI server port
MAX_TURNS=10                   # Max conversation turns per session
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Aliyun (NLS) ─────────────────────────────────────────────
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_NLS_APPKEY=your_aliyun_nls_appkey

# ── DeepSeek (LLM) ──────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── Youdao (Oral Evaluation) ────────────────────────────────
YOUDAO_APP_KEY=your_youdao_app_key
YOUDAO_APP_SECRET=your_youdao_app_secret
